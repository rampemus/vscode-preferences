{
  "description": "Slack shortcuts",
  "manipulators": [
    {
      "description": "Open channel picker",
      "conditions": [
        {
          "bundle_identifiers": [
            "com.tinyspeck.slackmacgap"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "p",
        "modifiers": { "mandatory": ["command"] }
      },
      "to": {
        "key_code": "k",
        "modifiers": ["command"]
      },
      "type": "basic"
    },
    {
      "description": "Reload page (force)",
      "conditions": [
        {
          "bundle_identifiers": [
            "com.tinyspeck.slackmacgap"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "c",
        "modifiers": { "mandatory": ["control"] }
      },
      "to": {
        "key_code": "r",
        "modifiers": ["command", "shift"]
      },
      "type": "basic"
    }
  ]
}

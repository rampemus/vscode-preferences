{
  "description": "Mail shortcuts",
  "manipulators": [
    {
      "description": "Global search",
      "conditions": [
        {
          "bundle_identifiers": ["com.apple.mail"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "f",
        "modifiers": { "mandatory": ["command", "shift"] }
      },
      "to": [
        {
          "key_code": "f",
          "modifiers": ["command", "option"]
        }
      ],
      "type": "basic"
    }
  ]
}
